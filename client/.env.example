# Copy to .env.local for local dev. Vite picks .env.local up automatically.
#
# By default the client serves from the same origin as the Worker, so
# leave VITE_API_URL unset for a Worker-hosted deploy.
#
# For local `npm run dev`, point at the dev Cloudflare backend so the React
# app talks to real D1/R2 data — no need to run a local Express server.
#
# VITE_API_URL=https://trek-api-dev.dylansalim015.workers.dev
